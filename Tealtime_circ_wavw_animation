if __name__ == "__main__":
    print("🚀 Launching Real-Time Hidden State Circular Wave Engine...")
    viz = RealTime369Visualizer()
    
    ani = animation.FuncAnimation(viz.fig, viz.update, frames=None,
                                  interval=45, blit=True, cache_frame_data=False)
    
    plt.tight_layout()
    plt.show()
